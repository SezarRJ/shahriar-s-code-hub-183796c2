# ============================================================
# SHAHID Platform — Environment Configuration
# Copy this file to .env and fill in real values for local dev
# NEVER commit .env files to Git (already in .gitignore)
# ============================================================

# ─────────────────────────────────────────────────────────────
# General
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# API Gateway (services/api-gateway)
# ─────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3001
SUPABASE_URL=http://supabase-auth:9999
SUPABASE_SERVICE_KEY=your-super-secret-jwt-key-for-local-dev-only
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL via Supabase local / Docker)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ─────────────────────────────────────────────────────────────
# Redis (Cache / Queue)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# S3 / MinIO (Object Storage)
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=shahid-photos
S3_REPORTS_BUCKET=shahid-reports
S3_REGION=us-east-1

# ─────────────────────────────────────────────────────────────
# Report Service (services/report-service)
# ─────────────────────────────────────────────────────────────
REPORT_SERVICE_PORT=3002

# ─────────────────────────────────────────────────────────────
# Notification Service (services/notification-service)
# ─────────────────────────────────────────────────────────────
NOTIFICATION_SERVICE_PORT=3003
FCM_SERVER_KEY=your-firebase-cloud-messaging-server-key
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────────────────────
# AI Service (services/ai-service)
# ─────────────────────────────────────────────────────────────
AI_SERVICE_PORT=5001
GOOGLE_VISION_API_KEY=your-google-vision-api-key
ANTHROPIC_API_KEY=your-anthropic-claude-api-key

# ─────────────────────────────────────────────────────────────
# Storage Service (services/storage-service)
# ─────────────────────────────────────────────────────────────
STORAGE_SERVICE_PORT=3004

# ─────────────────────────────────────────────────────────────
# Web Dashboard (apps/web)
# ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api/v1

# ─────────────────────────────────────────────────────────────
# Flutter / Mobile (apps/mobile)
# ─────────────────────────────────────────────────────────────
# No build-time env needed; runtime config from API Gateway

# ─────────────────────────────────────────────────────────────
# Optional: Blockchain / OpenTimestamps (Year 1 optional, Year 2+)
# ─────────────────────────────────────────────────────────────
OPENTIMESTAMPS_ENABLED=false

# ─────────────────────────────────────────────────────────────
# Slack / Monitoring (Production only)
# ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
